// Copia estas reglas en Firebase Console → Firestore → Reglas (ajusta según tu seguridad).
// Colección: posContadorInvitaciones — invitaciones cajero → contador (fallback POS).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /posContadorInvitaciones/{id} {
      // Crear: solo el usuario autenticado como invitador
      allow create: if request.auth != null
        && request.resource.data.inviterUid == request.auth.uid
        && request.resource.data.estado == 'pendiente';

      // Leer: el invitador ve las suyas; el invitado puede leer pendientes por su email (completar registro)
      allow read: if request.auth != null && (
        resource.data.inviterUid == request.auth.uid
        || (resource.data.inviteeEmail == request.auth.token.email.lower()
            && resource.data.estado == 'pendiente')
      );

      // Invitado acepta, o invitador anula pendiente (libera cupo).
      allow update: if request.auth != null && (
        (
          resource.data.inviteeEmail == request.auth.token.email.lower()
          && resource.data.estado == 'pendiente'
          && request.resource.data.estado == 'aceptada'
        )
        || (
          resource.data.inviterUid == request.auth.uid
          && resource.data.estado == 'pendiente'
          && request.resource.data.estado == 'cancelada'
          && request.resource.data.inviterUid == resource.data.inviterUid
          && request.resource.data.inviteeEmail == resource.data.inviteeEmail
          && request.resource.data.puntoVenta == resource.data.puntoVenta
        )
      );

      allow delete: if false;
    }

    // Catálogo de insumos (solo lectura desde el POS; la carga la hace backoffice / importación).
    match /DB_Franquicia_Insumos_Kit/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Inventario POS: saldos y movimientos acotados al punto de venta del usuario en users/{uid}.
    function posInventarioPuntoVentaUsuario() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.puntoVenta;
    }

    match /posInventarioSaldos/{id} {
      // `resource == null`: el POS hace get en transacción antes de crear el saldo; si el doc no existe,
      // `resource.data` fallaba y Firestore devolvía permission-denied (p. ej. primer cargue FRAN-KIT-6).
      allow read: if request.auth != null
        && (
          resource == null
          || resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        );
      allow create: if request.auth != null
        && request.resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        && request.resource.data.keys().hasAll(['puntoVenta', 'insumoId', 'cantidad']);
      allow update: if request.auth != null
        && resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        && request.resource.data.puntoVenta == resource.data.puntoVenta
        && request.resource.data.insumoId == resource.data.insumoId;
      allow delete: if false;
    }

    // Mínimos sugeridos editados en pantalla Inventarios (por PV + SKU).
    match /posInventarioMinimos/{id} {
      allow read: if request.auth != null
        && (
          resource == null
          || resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        );
      allow create, update: if request.auth != null
        && request.resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['puntoVenta', 'insumoSku', 'minimo', 'uid']);
      allow delete: if request.auth != null
        && resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        && resource.data.uid == request.auth.uid;
    }

    // Cajeros operativos por punto de venta (selección al abrir turno en el POS).
    function posUsuarioPuntoVenta() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.puntoVenta;
    }

    function posUsuarioDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function posPuedeGestionarCajerosTurno() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && !(
          posUsuarioDoc().data.keys().hasAny(['role'])
          && posUsuarioDoc().data.role == 'pos_contador'
        )
        && !(
          posUsuarioDoc().data.keys().hasAny(['rol'])
          && posUsuarioDoc().data.rol == 'pos_contador'
        );
    }

    function posMismoPuntoVenta(datoPv) {
      let u = posUsuarioPuntoVenta();
      return datoPv == u
        || (datoPv is string && u is string && datoPv.lower() == u.lower());
    }

    /** true si users/{uid} existe y no es contador invitado (sin campo role = franquiciado). */
    function usuarioFranquiciadoPuedeDocumentosComerciales() {
      return posPuedeGestionarCajerosTurno();
    }

    match /posCajerosTurno/{id} {
      allow read: if request.auth != null
        && posMismoPuntoVenta(resource.data.puntoVenta);

      allow create: if request.auth != null
        && posPuedeGestionarCajerosTurno()
        && posMismoPuntoVenta(request.resource.data.puntoVenta)
        && request.resource.data.activo == true
        && request.resource.data.keys().hasAll(['puntoVenta', 'activo', 'ficha', 'createdByUid']);

      allow update: if request.auth != null
        && posPuedeGestionarCajerosTurno()
        && posMismoPuntoVenta(resource.data.puntoVenta)
        && posMismoPuntoVenta(request.resource.data.puntoVenta);

      allow delete: if request.auth != null
        && posPuedeGestionarCajerosTurno()
        && posMismoPuntoVenta(resource.data.puntoVenta);
    }

    match /pos_cajero_identificado/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Cotizaciones y remisiones (PDF) por punto de venta; solo franquiciado (no pos_contador).
    // Nota: no exijas createdAt/updatedAt en keys().hasAll — con serverTimestamp() el motor no siempre
    // los incluye en keys() al validar create, y el permiso falla con "Missing or insufficient permissions".
    match /posDocumentosComerciales/{id} {
      allow read: if request.auth != null
        && usuarioFranquiciadoPuedeDocumentosComerciales()
        && resource.data.puntoVenta == posUsuarioPuntoVenta();

      allow create: if request.auth != null
        && usuarioFranquiciadoPuedeDocumentosComerciales()
        && request.resource.data.puntoVenta == posUsuarioPuntoVenta()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.tipo in ['cotizacion', 'remision']
        && request.resource.data.lineas is list
        && request.resource.data.keys().hasAll([
          'tipo', 'numeroDocumento', 'fechaIso', 'puntoVenta', 'createdByUid', 'clienteNombre', 'lineas'
        ]);

      allow update: if request.auth != null
        && usuarioFranquiciadoPuedeDocumentosComerciales()
        && resource.data.puntoVenta == posUsuarioPuntoVenta()
        && request.resource.data.puntoVenta == resource.data.puntoVenta
        && request.resource.data.tipo == resource.data.tipo
        && request.resource.data.createdByUid == resource.data.createdByUid;

      allow delete: if request.auth != null
        && usuarioFranquiciadoPuedeDocumentosComerciales()
        && resource.data.puntoVenta == posUsuarioPuntoVenta();
    }

    match /posInventarioMovimientos/{id} {
      allow read: if request.auth != null
        && (
          resource == null
          || resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        );
      allow create: if request.auth != null
        && request.resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['puntoVenta', 'insumoId', 'tipo', 'delta', 'uid']);
      allow update, delete: if false;
    }

    // WMS — inventario ensamble (solo lectura desde el POS; el WMS escribe con Admin SDK).
    match /pos_inventario_ensamble_saldo/{id} {
      allow read: if request.auth != null
        && (
          resource == null
          || resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        );
      allow write: if false;
    }

    match /pos_inventario_ensamble_movimientos/{id} {
      allow read: if request.auth != null
        && (
          resource == null
          || resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        );
      allow write: if false;
    }

    // Idempotencia venta ensamble (WMS); el cliente POS no necesita leer/escribir aquí.
    match /pos_inventario_ensamble_venta_idem/{id} {
      allow read, write: if false;
    }

    // Clientes del franquiciado por punto de venta (POS — fidelización / ventas).
    match /posClientes/{id} {
      allow read: if request.auth != null
        && resource.data.puntoVenta == posInventarioPuntoVentaUsuario();
      allow create: if request.auth != null
        && posUsuarioRol() != 'pos_contador'
        && request.resource.data.puntoVenta == posInventarioPuntoVentaUsuario()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.keys().hasAll([
          'puntoVenta', 'tipoCliente', 'tipoIdentificacion', 'numeroIdentificacion', 'createdByUid'
        ]);
      allow update, delete: if false;
    }

    // TestSetId DIAN por punto (franquiciado guarda; administración lee en consola / WMS).
    match /posDianHabilitacion/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Avisos en bandeja del POS (escritura solo servidor; lectura del propio usuario).
    match /posNotificacionesCaja/{id} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Usuarios POS: contador (role pos_contador) no puede cambiar punto de venta, rol ni invitadoPorUid desde el cliente.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && (
          !(resource.data.keys().hasAny(['role']) && resource.data.role == 'pos_contador')
          || (
            request.resource.data.puntoVenta == resource.data.puntoVenta
            && request.resource.data.role == resource.data.role
            && (!resource.data.keys().hasAny(['invitadoPorUid'])
              || request.resource.data.invitadoPorUid == resource.data.invitadoPorUid)
          )
        );
      allow delete: if false;
    }
  }
}
