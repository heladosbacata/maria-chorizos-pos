{
  "name": "maria-chorizos-pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3040",
    "dev:restart": "npx --yes kill-port 3040 && next dev -p 3040",
    "dev:3000": "next dev -p 3000",
    "dev:3004": "next dev -p 3004",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3040",
    "dev:fresh": "node scripts/dev-fresh.mjs",
    "dev:repair": "node scripts/dev-fresh.mjs",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('.next eliminado')}catch(e){console.error(e);process.exit(1)}\"",
    "clean:cache": "node -e \"try{require('fs').rmSync('node_modules/.cache',{recursive:true,force:true});console.log('node_modules/.cache eliminado')}catch(e){console.log('sin .cache o ya limpio')}\"",
    "build": "next build",
    "start": "next start -p 3040",
    "lint": "next lint",
    "check:inventario": "node scripts/verificar-inventario-env.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "firebase": "^10.7.1",
    "firebase-admin": "^12.7.0",
    "google-auth-library": "^9.15.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "next": "14.2.15",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.4",
    "qz-tray": "^2.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.5"
  }
}
