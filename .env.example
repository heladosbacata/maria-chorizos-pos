# Desarrollo: `npm run dev` arranca el POS en http://localhost:3040 (evita choque con otra app en :3000).
# Si ves 404 en webpack.js / main.js, suele ser abrir el puerto equivocado o caché: usa la URL que muestra la terminal o `npm run dev:clean`.
#
# Opcional: notificaciones push Web en /pedidos cuando el POS cambia el estado del domicilio (aunque el cliente cambie de app).
# Generar claves: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY= (clave pública, una línea)
# VAPID_PRIVATE_KEY= (clave privada, solo servidor — nunca en el cliente)
# VAPID_SUBJECT=mailto:servicio@tudominio.com
# Requiere HTTPS en producción y colección Firestore posDomiciliosPushSubs (o modo memoria local sin Firebase Admin).

# URL pública del landing que abren los QR de domicilios (módulo POS, tirilla y reimpresiones).
# Debe ser accesible desde celulares; nunca usar localhost para QR de clientes.
NEXT_PUBLIC_POS_LANDING_PEDIDOS_URL=https://maria-chorizos-pos.vercel.app/pedidos

# WMS (catálogo, ensamble, ventas, turnos POST /api/pos/turnos/abrir|sincronizar|cerrar, metas /api/pos/metas-retos/activas, etc.).
# Los turnos usan la misma base Firestore del WMS: CORS, mismo Firebase Auth y puntoVenta en users/{uid}.
# Por defecto el POS usa Vercel si no defines URL o si apuntas a localhost sin flag.
# Recomendado en equipos sin servidor local (deja la línea de URL comentada o usa la de Vercel):
NEXT_PUBLIC_WMS_URL=https://maria-chorizos-wms.vercel.app
# Misma base del WMS (opcional; si no existe, se usa NEXT_PUBLIC_WMS_URL):
# NEXT_PUBLIC_WMS_API_URL=https://maria-chorizos-wms.vercel.app
# Solo desarrollo con WMS en tu PC: descomenta y añade USE_LOCAL=1
# NEXT_PUBLIC_WMS_URL=http://localhost:3002
# NEXT_PUBLIC_WMS_USE_LOCAL=1
# Opcional: el proxy de ensamble expone en JSON/headers la URL del WMS (soporte / Vercel). Valor 1.
# POS_EXPOSE_WMS_UPSTREAM=1
#
# Desglose IVA en cobro/ticket (precios con IVA incluido). Debe coincidir con ALEGRA_POS_IVA_TASA en el WMS (por defecto 0.19).
# NEXT_PUBLIC_POS_IVA_TASA=0.19

# --- Club de Millas (solo servidor del POS; mismo valor que CLUB_MILLAS_POS_SECRET en el WMS) ---
# El POS llama POST /api/club-de-millas/pos/registrar-ticket solo desde /api/club_millas_registrar_ticket (nunca desde el bundle).
# Cuerpo hacia el WMS incluye montoTotalCop (entero COP, ej. 18000), opcionales idFacturaPos y cajaId; millas = floor(montoTotalCop/9000).
# Requiere FIREBASE_SERVICE_ACCOUNT_JSON para verificar el token del cajero.
# CLUB_MILLAS_POS_SECRET=
# Opcional: en el servidor del POS, loguear montoTotalCop y prefijo de qrPayload tras registrar ticket (no loguea el secreto).
# CLUB_MILLAS_DEBUG_LOG=1
# Opcional: cabecera personalizada hacia el WMS (formato "Nombre: valor"). Si no se define, se envía x-club-millas-pos-secret: <secreto>.
# CLUB_MILLAS_WMS_SECRET_HEADER=Authorization: Bearer tu_secreto_aqui
# Validación «cliente frecuente» / plan de millas: proxy GET|POST al WMS (mismo dominio que el catálogo).
# Respuesta WMS (opcional, caja): nombre (nombre, nombreCompleto, …) y saldo (millas, puntos, saldoMillas, totalPuntos, …) en raíz o en data/result/payload/cliente/clubDeMillas/planMillas/fidelizacion.
# Sin variable, el POS prueba por defecto varias rutas bajo /api/club-de-millas/…; con variable, solo las listadas (coma = orden):
# WMS_CLUB_VALIDAR_DOCUMENTO_PATH=/api/club-de-millas/pos/validar-documento
# WMS_CLUB_VALIDAR_DOCUMENTO_PATH=/api/club-de-millas/pos/validar-documento,/api/club-de-millas/validar-documento

# Opcional: tras crear cliente en Firestore (`/api/pos_cliente_crear`), el POS reenvía el mismo JSON al WMS (Bearer del cajero).
# El WMS debe exponer POST en esa ruta y aceptar los mismos campos + idDocumentoFirestore + origenAlta: "pos".
# Ruta en el WMS (mismo host que el catálogo). Defecto recomendado en WMS: POST /api/club-de-millas/pos/upsert-socio
# (alias /api/pos/club-de-millas/upsert-socio). Auth: x-club-millas-pos-secret = CLUB_MILLAS_POS_SECRET (no Bearer del cajero).
# WMS_POS_CLIENTE_UPSERT_PATH=/api/club-de-millas/pos/upsert-socio
# Cuerpo: mismos campos que posClientes + idDocumentoFirestore + origenAlta: "pos" + pinAccesoClubMillasInicial (4 dígitos si hubo correo de bienvenida).

# Correo de bienvenida al plan de millas al crear cliente (`/api/pos_cliente_crear` con e-mail válido). Mismas variables que informe de cierre: SMTP_* o ZOHO_* o RESEND_*.
# URLs en el correo (opcional; por defecto WMS mi-plan y mariachorizos.com):
# CLUB_MILLAS_MI_PLAN_URL=https://maria-chorizos-wms.vercel.app/club-de-millas/mi-plan
# QR en tirilla (cliente frecuente). Modo url (defecto): https://…/club-de-millas?c=BACATA-… (login y luego escanear de nuevo en Mi plan).
# Modo token: solo BACATA-CLUB-V1-… si el escáner premium no lee URLs.
# NEXT_PUBLIC_CLUB_MILLAS_QR_MODO=url
# NEXT_PUBLIC_CLUB_MILLAS_PORTAL_URL=https://maria-chorizos-wms.vercel.app/club-de-millas
# NEXT_PUBLIC_CLUB_MILLAS_QR_QUERY_PARAM=c
# El WMS devuelve codigoCorto (6 letras) en registrar-ticket; va impreso en tirilla para escaner premium.
# MARIA_CHORIZOS_WEB_URL=https://mariachorizos.com

# Hora oficial Colombia (COT) en servidor Node/Vercel; el cliente formatea con America/Bogota en src/lib/fecha-colombia.ts
# TZ=America/Bogota

# Firebase (mismos valores que el proyecto WMS: maria-chorizos-wms)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcional: crear cajeros POS sin WMS (cuenta de servicio del MISMO proyecto Firebase, JSON en una línea).
# Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada.
# En Windows PowerShell puedes escapar comillas; en Vercel pega el JSON completo como valor de la variable.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# En Vercel del POS: necesaria para registrar/listar ventas en Firestore (colección posVentasCloud), correo de cierre de turno y creación de cajeros sin WMS.
#
# Desarrollo local SIN copiar la cuenta de servicio: reenvía ventas nube al POS en Vercel (mismo Firebase, tu sesión).
# Crea .env.local con esta línea y reinicia npm run dev:
# POS_VENTAS_CLOUD_PROXY_URL=https://maria-chorizos-pos.vercel.app
# (Alias equivalente: POS_DEPLOY_PROXY_URL — también reenvía envío de correos /api/pos_turno_informe_correo en local.)
# POS_DEPLOY_PROXY_URL=https://maria-chorizos-pos.vercel.app
# (Opcional: la misma clave en Vercel solo si quisieras proxy también en producción — no recomendado.)
# POS_VENTAS_CLOUD_PROXY_IN_PRODUCTION=1
# Reinicio a fábrica (Contrato POS GEB): sin esta variable el servidor no puede borrar Firestore; el navegador igual se limpia. Clave por defecto en código MC2026.
# POS_REINICIO_FABRICA_CLAVE=

# --- Correo: informe al cerrar turno (POST /api/pos_turno_informe_correo) ---
# Prioridad: 1) SMTP genérico (SMTP_HOST, SMTP_USER, SMTP_PASS); 2) Zoho/Resend vía posCierreInformeEmail.
# No subas contraseñas al repo: .env.local o Vercel.
#
# Opción A — SMTP genérico (hosting, Outlook, etc.):
# SMTP_HOST=smtp.tuproveedor.com
# SMTP_PORT=587
# SMTP_USER=tu@correo.com
# SMTP_PASS=clave_o_app_password
# SMTP_FROM=Maria Chorizos <tu@correo.com>
# Puerto 465 SSL: SMTP_PORT=465 y SMTP_SECURE=1
# Solo pruebas con certificado raro: SMTP_TLS_REJECT_UNAUTHORIZED=0
#
# Opción B — Zoho (mismas variables que maria-chorizos-wms) si no usás la opción A:
# ZOHO_SMTP_USER=servicioalcliente@grupobacata.com
# ZOHO_SMTP_PASSWORD=contraseña_de_aplicación_zoho
# ZOHO_SMTP_FROM=Servicio al cliente Grupo Bacatá <servicioalcliente@grupobacata.com>
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=465
# ZOHO_SMTP_SECURE=true
#
# Opción C — Resend (HTTP), si no hay SMTP ni Zoho:
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Maria Chorizos POS <onboarding@resend.dev>

# Secreto compartido (WMS y POS): el WMS llama POST /api/wms_provision_usuario al crear o actualizar un usuario POS para replicarlo en Firebase Auth + users/{uid}.
# Genera un valor largo aleatorio; el mismo debe estar en las variables del WMS para firmar la petición (Authorization: Bearer ...).
# POS_WMS_PROVISION_SECRET=

# Catálogo de insumos para «Cargue de inventario» (Google Sheet Maria Chorizos por defecto).
# Opción recomendada — Cuenta de servicio con la hoja compartida como Editor/Lector (hoja «Restringida» OK).
# JSON en una línea (la misma clave que descargas en Google Cloud → IAM → cuenta de servicio → claves).
# En el Sheet: compartir con el email client_email de esa cuenta (p. ej. bot-inventario@....iam.gserviceaccount.com).
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# Si la cuenta de servicio de Firebase ya es editora de la hoja, puedes reutilizarla sin duplicar JSON:
# GOOGLE_SHEETS_USE_FIREBASE_SA=1
# Pasos únicos (API + compartir hoja con client_email): docs/GOOGLE_SHEETS_AUTOMATIZAR_POS.md
# Opcional: otro spreadsheet / pestaña (gid de la URL, ej. 415609818).
# GOOGLE_SHEETS_INSUMOS_SPREADSHEET_ID=1c1Ihhx0mtGduvNLPN_DIURK5AJYU2JJ9oIbChDVaABQ
# GOOGLE_SHEETS_INSUMOS_GID=415609818
# Si el título de la pestaña no coincide con el gid, define el rango A1:
# GOOGLE_SHEETS_INSUMOS_RANGE='Hoja1'!A:Z
# Opción — API key (solo si la hoja es «Cualquiera con el enlace: lector» o pública). Google Sheets API habilitada.
# GOOGLE_SHEETS_API_KEY=
# Opción — CSV publicado (Archivo → Compartir → Publicar en la web → CSV). Prioridad máxima si está definida.
# GOOGLE_SHEETS_INSUMOS_CSV_URL=
#
# Exportar clientes POS a Google Sheets (Más → Clientes y proveedores → «Enviar a Google Sheet»).
# La cuenta de servicio debe tener permiso de EDITOR en la pestaña. Creá una pestaña (ej. DB_Pos_Clientes) y definí el rango A1 completo:
# GOOGLE_SHEETS_CLIENTES_RANGE='DB_Pos_Clientes'!A:P
# Opcional: otro spreadsheet que no sea el de insumos (si no, se usa el mismo ID que insumos por defecto del código / GOOGLE_SHEETS_INSUMOS_SPREADSHEET_ID).
# GOOGLE_SHEETS_CLIENTES_SPREADSHEET_ID=

# Catálogo Firestore «DB_Franquicia_Insumos_Kit» (cliente POS): consultas indexadas en paralelo + escaneo compat.
# Tras migrar docs con posCatalogoGlobal / posCatalogoPvCodes / puntoVenta, pon 1 en prod para no escanear la colección.
# NEXT_PUBLIC_POS_CATALOGO_FIRESTORE_INDEXED_ONLY=1
# Límite por consulta indexada (50–1000, default 500):
# NEXT_PUBLIC_POS_CATALOGO_FIRESTORE_LIMIT=500
# Tope de documentos en el escaneo de compat. (solo si INDEXED_ONLY no está activo):
# NEXT_PUBLIC_POS_CATALOGO_LEGACY_SCAN_LIMIT=2500
#
# Checklist inventario POS (qué falta en Firebase / pruebas): docs/CHECKLIST_INVENTARIO.md
# Comprobar variables locales: npm run check:inventario

# Caja — botón «Producto para llevar»: descuenta bolsa de papel y sticker de domicilio (consumo interno).
# Opcional pero recomendado: SKU exacto del catálogo. Si no están, el POS intenta encontrar ítems por nombre en la hoja/Firestore.
# NEXT_PUBLIC_POS_SKU_BOLSA_PAPEL=
# NEXT_PUBLIC_POS_SKU_STICKER_DOMICILIO=
# Caja — «Soy cliente frecuente»: descuenta 1 unidad (consumo interno) al activar el modo; mismo SKU que en la hoja de insumos.
# NEXT_PUBLIC_POS_SKU_STICKER_FIDELIZACION=

# QZ Tray — firma digital (evita «Anonymous / Untrusted» y suele hacer efectiva «Remember this decision»).
# Guía: https://qz.io/docs/signing · Requiere FIREBASE_SERVICE_ACCOUNT_JSON en el servidor para validar el token al firmar.
# NEXT_PUBLIC_POS_QZ_SIGNING=1
# Mismo algoritmo en cliente y API (SHA512 recomendado con certificados nuevos de QZ).
# NEXT_PUBLIC_POS_QZ_SIGN_ALGORITHM=SHA512
# POS_QZ_SIGN_ALGORITHM=SHA512
# Certificado público y clave privada (en .env.local podés usar comillas y saltos de línea reales; en Vercel a veces conviene \n escapados en una sola línea).
# POS_QZ_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# POS_QZ_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
